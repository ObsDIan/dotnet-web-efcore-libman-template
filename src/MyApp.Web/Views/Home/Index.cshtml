@model IReadOnlyList<MyApp.Domain.Entities.Category>

@{
    ViewData["Title"] = "Home";
}

<h1>Categories</h1>

@if (Model.Count == 0)
{
    <p>No categories found.</p>
}
else
{
    <ul>
        @foreach (var category in Model)
        {
            <li>
                <strong>@category.Name</strong>
                <span>(@category.Posts.Count posts)</span>
            </li>
        }
    </ul>
}
